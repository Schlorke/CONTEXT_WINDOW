{
  "name": "context-window",
  "version": "1.10.0",
  "private": true,
  "description": "Portable SaaS skills library with QA, evals, and export tooling.",
  "scripts": {
    "audit:skills": "node scripts/audit-skills.mjs",
    "evals:init": "node scripts/init-skill-replay.mjs",
    "evals:score": "node scripts/score-skill-replays.mjs",
    "qa:skills": "pnpm audit:skills && pnpm lint:md && pnpm export:flat-skills && pnpm export:cursor-rules && pnpm export:cursor-user-rules && pnpm install:agent-runtimes -- dist/agent-runtime-smoke-test --global-all --codex-home dist/agent-runtime-smoke-test/.codex-home --claude-home dist/agent-runtime-smoke-test/.claude-home --cursor-home dist/agent-runtime-smoke-test/.cursor-home && pnpm verify:agent-runtimes -- dist/agent-runtime-smoke-test --global-all --codex-home dist/agent-runtime-smoke-test/.codex-home --claude-home dist/agent-runtime-smoke-test/.claude-home --cursor-home dist/agent-runtime-smoke-test/.cursor-home && pnpm status:agent-runtimes -- dist/agent-runtime-smoke-test --global-all --codex-home dist/agent-runtime-smoke-test/.codex-home --claude-home dist/agent-runtime-smoke-test/.claude-home --cursor-home dist/agent-runtime-smoke-test/.cursor-home",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "fix:md": "node scripts/fix-markdownlint.mjs && pnpm lint:md:fix && prettier --write .",
    "export:flat-skills": "node scripts/export-flat-skills.mjs",
    "export:cursor-rules": "node scripts/export-cursor-rules.mjs",
    "export:cursor-user-rules": "node scripts/export-cursor-user-rules.mjs",
    "install:agent-runtimes": "node scripts/install-agent-runtimes.mjs",
    "sync:agent-runtimes": "node scripts/install-agent-runtimes.mjs",
    "install:global-runtimes": "node scripts/install-agent-runtimes.mjs . --global-only --global-all",
    "sync:global-runtimes": "node scripts/install-agent-runtimes.mjs . --global-only --global-all",
    "install:codex": "node scripts/install-agent-runtimes.mjs --codex-only",
    "install:claude": "node scripts/install-agent-runtimes.mjs --claude-only",
    "install:cursor": "node scripts/install-agent-runtimes.mjs --cursor-only",
    "install:claude-global": "node scripts/install-agent-runtimes.mjs . --global-only --global-claude --skip-codex",
    "install:cursor-global": "node scripts/install-agent-runtimes.mjs . --global-only --global-cursor --skip-codex",
    "install:skill-usage-reporting": "node scripts/install-skill-usage-reporting.mjs",
    "sync:codex": "node scripts/install-agent-runtimes.mjs --codex-only",
    "sync:claude": "node scripts/install-agent-runtimes.mjs --claude-only",
    "sync:cursor": "node scripts/install-agent-runtimes.mjs --cursor-only",
    "sync:claude-global": "node scripts/install-agent-runtimes.mjs . --global-only --global-claude --skip-codex",
    "sync:cursor-global": "node scripts/install-agent-runtimes.mjs . --global-only --global-cursor --skip-codex",
    "install:ide-runtime": "node scripts/install-ide-runtime.mjs",
    "verify:agent-runtimes": "node scripts/verify-agent-runtimes.mjs",
    "verify:global-runtimes": "node scripts/verify-agent-runtimes.mjs . --global-only --global-all",
    "verify:codex": "node scripts/verify-agent-runtimes.mjs --codex-only",
    "verify:claude": "node scripts/verify-agent-runtimes.mjs --claude-only",
    "verify:cursor": "node scripts/verify-agent-runtimes.mjs --cursor-only",
    "verify:claude-global": "node scripts/verify-agent-runtimes.mjs . --global-only --global-claude --skip-codex",
    "verify:cursor-global": "node scripts/verify-agent-runtimes.mjs . --global-only --global-cursor --skip-codex",
    "verify:skill-usage-reporting": "node scripts/verify-skill-usage-reporting.mjs",
    "status:agent-runtimes": "node scripts/status-agent-runtimes.mjs",
    "status:global-runtimes": "node scripts/status-agent-runtimes.mjs . --global-only --global-all",
    "verify:ide-runtime": "node scripts/verify-ide-runtime.mjs"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.2"
  }
}
